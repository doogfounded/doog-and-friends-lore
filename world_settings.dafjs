// world_settings.dafjs

ENVIRONMENT {
    gravity = 9.807; // Standard Earth gravity 
    air_resistance = 0.05;
    physics_engine = "Source-Style"; // Allows for Rocket Jumping/Strafing
}

TIMELINE {
    current_year = 2026;
    epoch = "10,000 years ago"; // When the everyone was first 'compiled'
}

CAPABILITIES {
    rocket_jumping = TRUE;
    fall_damage_scaling = 0.5; // To survive those jumps!
}
